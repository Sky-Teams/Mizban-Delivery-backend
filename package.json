  "main": "src/server.js",
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "dev": "nodemon src/server.js",
    "dev:api": "nodemon src/server.js",
    "start:api": "node src/server.js",
    "worker:dev": "nodemon src/workers.js",
    "start": "node src/server.js",
    "lint": "eslint src/**/*.js",
    "worker": "node src/workers.js",
    "lint:fix": "eslint src/**/*.js --fix",
    "format": "prettier --write src/**/*.js",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest --coverage",
    "test:unit": "vitest src/tests/unit",
    "test:integration": "vitest src/tests/integration",
    "test:e2e": "vitest src/tests/e2e",
    "test:specific": "vitest",
    "seed": "node src/scripts/seed.js"
  },
  "imports": {
    "#shared/*": "./src/shared/*",
    "#modules/*": "./src/modules/*",
    "#tests/*": "./src/tests/*",
    "#config/*": "./src/config/*",
    "#root": "./*"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "@agendajs/mongo-backend": "^4.0.0",
    "agenda": "^6.2.3",
    "axios": "^1.14.0",
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "libphonenumber-js": "^1.12.37",
    "mongodb-memory-server": "^11.0.1",
    "mongoose": "^9.2.1",
    "pino": "^10.3.1",
    "pino-abstract-transport": "^3.0.0",
    "pino-roll": "^4.0.0",
    "socket.io": "^4.8.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^10.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.3.0",
    "mongodb-memory-server": "^11.0.1",
    "nodemon": "^3.1.11",
    "prettier": "^3.8.1",
    "supertest": "^7.2.2",
    "vitest": "^4.0.18"
